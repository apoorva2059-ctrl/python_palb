1. class Solution {
  public:
    int minSwaps(string& s1, string& s2) {
        int count01 = 0, count10 = 0;
        
        for(int i = 0; i < s1.size(); i++) {
            if(s1[i] == '0' && s2[i] == '1') {
                count01++;
            }
            else if(s1[i] == '1' && s2[i] == '0') {
                count10++;
            }
        }
        
        // If total mismatches are odd → impossible
        if((count01 + count10) % 2 != 0) {
            return -1;
        }
        
        int swaps = 0;
        
        // Pair same mismatches
        swaps += count01 / 2;
        swaps += count10 / 2;
        
        // If one of each remains → need 2 swaps
        if(count01 % 2 == 1) {
            swaps += 2;
        }
        
        return swaps;
    }
};

2.   class Solution {
  public:
    int minParentheses(string& s) {
        int open = 0;  // unmatched '('
        int add = 0;   // insertions needed
        
        for(char c : s) {
            if(c == '(') {
                open++;
            } 
            else { // ')'
                if(open > 0) {
                    open--;   // match
                } else {
                    add++;    // need '('
                }
            }
        }
        
        // remaining '(' need ')'
        add += open;
        
        return add;
    }
};


3.   class Solution {
  public:
    int scoreOfParentheses(string& s) {
        int score = 0;
        int depth = 0;
        
        for(int i = 0; i < s.size(); i++) {
            if(s[i] == '(') {
                depth++;
            } else {
                depth--;
                
                // Check for "()"
                if(s[i-1] == '(') {
                    score += (1 << depth);
                }
            }
        }
        
        return score;
    }
};



4.   class Solution {
  public:
    int minDifference(vector<string> &arr) {
        vector<int> times;
        
        // Convert to seconds
        for(string t : arr) {
            int h = stoi(t.substr(0, 2));
            int m = stoi(t.substr(3, 2));
            int s = stoi(t.substr(6, 2));
            
            int total = h * 3600 + m * 60 + s;
            times.push_back(total);
        }
        
        // Sort times
        sort(times.begin(), times.end());
        
        int n = times.size();
        int ans = INT_MAX;
        
        // Adjacent differences
        for(int i = 1; i < n; i++) {
            ans = min(ans, times[i] - times[i-1]);
        }
        
        // Circular difference (last ↔ first)
        ans = min(ans, 86400 - times[n-1] + times[0]);
        
        return ans;
    }
};


5. class Solution {
  public:
    string frequencySort(string &s) {
        vector<int> freq(26, 0);
        
        // Step 1: Count frequency
        for(char c : s) {
            freq[c - 'a']++;
        }
        
        // Step 2: Store characters
        vector<pair<int, char>> v;
        
        for(int i = 0; i < 26; i++) {
            if(freq[i] > 0) {
                v.push_back({freq[i], char('a' + i)});
            }
        }
        
        // Step 3: Sort
        sort(v.begin(), v.end(), [](auto &a, auto &b) {
            if(a.first == b.first)
                return a.second < b.second; // lexicographical
            return a.first < b.first;       // frequency
        });
        
        // Step 4: Build result
        string result = "";
        
        for(auto &p : v) {
            result += string(p.first, p.second);
        }
        
        return result;
    }
};


